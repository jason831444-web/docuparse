POSTGRES_DB=docuparse
POSTGRES_USER=docuparse
POSTGRES_PASSWORD=change-this-long-random-password

# Public origin users open in the browser. Include scheme, no trailing slash.
PUBLIC_BASE_URL=https://docuparse.example.com
CORS_ORIGINS=["https://docuparse.example.com"]
NEXT_PUBLIC_API_BASE_URL=/api
HTTP_PORT=80
MAX_UPLOAD_MB=64

# Build the backend image with the CPU-oriented GGUF runtime.
INSTALL_LLAMA_CPP_DEPS=true

# Keep false for the GGUF production path. Set true only when comparing the old
# Hugging Face/Transformers path or optional Paddle/Qwen runtimes.
INSTALL_AI_DEPS=false

# Server filesystem path containing the GGUF model file.
# This directory is mounted read-only into the backend at /models/gguf.
LLAMA_CPP_MODEL_DIR_ON_HOST=/srv/docuparse/models/gguf
LLAMA_CPP_MODEL_FILE=gemma-3-4b-it-q4_0.gguf
LLAMA_CPP_CONTEXT_WINDOW=4096
LLAMA_CPP_THREADS=0
LLAMA_CPP_GPU_LAYERS=0
LLAMA_CPP_MAX_TOKENS=700
LLAMA_CPP_TEMPERATURE=0.1

# Optional legacy Hugging Face model mount for comparison only.
GEMMA_MODEL_DIR=
GEMMA_MODEL_NAME=google/gemma-4-E4B-it
GEMMA_DEVICE=auto

AI_INTERPRETATION_ENABLED=true
AI_INTERPRETATION_PROVIDER=llama_cpp
AI_INTERPRETATION_MODEL=gguf-local
AI_INTERPRETATION_FALLBACK_MODEL=google/gemma-2-2b-it
AI_INTERPRETATION_ENABLE_MODEL_FALLBACK=true
AI_INTERPRETATION_FORCE_SMALL_MODEL=false
AI_INTERPRETATION_LOCAL_PREFER_SMALL_MODEL=false

AI_PROVIDER=auto
AI_PRIMARY_PROVIDER=paddleocr_vl
AI_SECONDARY_PROVIDER=qwen2_5_vl
AI_ENABLE_SECOND_PASS=true
AI_SECOND_PASS_CONFIDENCE_THRESHOLD=0.80
PADDLEOCR_VL_MODEL_DIR=
PADDLEOCR_VL_LAYOUT_MODEL_DIR=
PADDLEOCR_VL_DEVICE=cpu
QWEN2_5_VL_MODEL_DIR=
QWEN2_5_VL_DEVICE=auto
