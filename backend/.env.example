AI_SECONDARY_PROVIDER=qwen2_5_vl
AI_ENABLE_SECOND_PASS=true
AI_SECOND_PASS_CONFIDENCE_THRESHOLD=0.80
AI_MODEL_DIR=models
PADDLEOCR_VL_MODEL_DIR=
